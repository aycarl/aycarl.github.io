---
import Sun from './icons/Sun.astro';
import Moon from './icons/Moon.astro';
---

<button
  id="theme-toggle"
  type="button"
  class="p-2 rounded-lg bg-gray-200 dark:bg-gray-700 hover:bg-gray-300 dark:hover:bg-gray-600 focus:outline-none focus:ring-2 focus:ring-blue-600 transition-colors"
  aria-label="Toggle theme"
  aria-pressed="false"
>
  <span class="dark:hidden" aria-hidden="true">
    <Moon class="w-5 h-5 text-gray-800" />
  </span>
  <span class="hidden dark:block" aria-hidden="true">
    <Sun class="w-5 h-5 text-yellow-400" />
  </span>
  <span class="sr-only">Switch between light and dark mode</span>
</button>

<script>
  function initThemeToggle() {
    const button = document.getElementById('theme-toggle');
    if (!button) return;

    const handleToggleClick = () => {
      const element = document.documentElement;
      element.classList.toggle('dark');

      const isDark = element.classList.contains('dark');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');

      // Update aria-pressed for accessibility
      button.setAttribute('aria-pressed', isDark.toString());
      button.setAttribute('aria-label', isDark ? 'Switch to light mode' : 'Switch to dark mode');
    };

    // Remove any existing listeners and add new one
    button.addEventListener('click', handleToggleClick);

    // Set initial aria-pressed state
    const isDark = document.documentElement.classList.contains('dark');
    button.setAttribute('aria-pressed', isDark.toString());
    button.setAttribute('aria-label', isDark ? 'Switch to light mode' : 'Switch to dark mode');
  }

  // Run when DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initThemeToggle);
  } else {
    initThemeToggle();
  }
</script>
