---
// Modern Footer with Navigation
import GitHub from './icons/GitHub.astro';
import LinkedIn from './icons/LinkedIn.astro';
import Behance from './icons/Behance.astro';
---

<footer class="bg-gray-900 dark:bg-black text-gray-300 border-t border-gray-800" role="contentinfo">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-12">
    <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-6 sm:gap-8 mb-6 sm:mb-8">
      <!-- About -->
      <div class="sm:col-span-2 md:col-span-1">
        <div class="flex items-center space-x-2 mb-3 sm:mb-4">
          <div class="w-8 h-8 sm:w-10 sm:h-10 rounded-full bg-gradient-to-br from-blue-500 to-purple-600 flex items-center justify-center text-white font-bold text-sm sm:text-base" aria-hidden="true">
            CA
          </div>
          <span class="font-bold text-lg sm:text-xl text-white">Carl Agbenyega</span>
        </div>
        <p class="text-xs sm:text-sm text-gray-400">
          Full-stack software engineer with 8+ years of experience building web applications, REST APIs, and data-rich interfaces.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="font-bold text-white mb-3 sm:mb-4 text-sm sm:text-base">Navigation</h3>
        <nav aria-label="Footer navigation">
          <ul class="space-y-2" role="list">
            <li>
              <a href="/#experience" class="text-xs sm:text-sm text-gray-400 hover:text-blue-400 focus:text-blue-400 focus:outline-none focus:ring-2 focus:ring-blue-400 focus:ring-offset-2 focus:ring-offset-gray-900 rounded transition-colors">
                Experience
              </a>
            </li>
            <li>
              <a href="/#education" class="text-xs sm:text-sm text-gray-400 hover:text-blue-400 focus:text-blue-400 focus:outline-none focus:ring-2 focus:ring-blue-400 focus:ring-offset-2 focus:ring-offset-gray-900 rounded transition-colors">
                Education
              </a>
            </li>
            <li>
              <a href="/#skills" class="text-xs sm:text-sm text-gray-400 hover:text-blue-400 focus:text-blue-400 focus:outline-none focus:ring-2 focus:ring-blue-400 focus:ring-offset-2 focus:ring-offset-gray-900 rounded transition-colors">
                Skills
              </a>
            </li>
          </ul>
        </nav>
      </div>

      <!-- Contact & Social -->
      <div>
        <h3 class="font-bold text-white mb-3 sm:mb-4 text-sm sm:text-base">Connect</h3>
        <div class="space-y-3">
          <!-- Email & Phone -->
          <ul class="space-y-2" role="list">
            <li>
              <a href="mailto:aycarl@hotmail.com" class="text-xs sm:text-sm text-gray-400 hover:text-blue-400 focus:text-blue-400 focus:outline-none focus:ring-2 focus:ring-blue-400 focus:ring-offset-2 focus:ring-offset-gray-900 rounded transition-colors flex items-center gap-2" aria-label="Send me an email">
                <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                  <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"></path>
                  <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"></path>
                </svg>
                <span class="break-all">aycarl@hotmail.com</span>
              </a>
            </li>
            <li>
              <span class="text-xs sm:text-sm text-gray-400 flex items-center gap-2">
                <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                  <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"></path>
                </svg>
                <span>+1 (505) 359-1888</span>
              </span>
            </li>
          </ul>

          <!-- Social Links -->
          <div>
            <p class="text-xs font-semibold text-gray-500 mb-2">Social</p>
            <div class="flex gap-2" role="list" aria-label="Social media links">
              <a
                href="https://github.com/aycarl"
                target="_blank"
                rel="noopener noreferrer"
                class="p-2 rounded-lg bg-gray-800 hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-blue-400 focus:ring-offset-2 focus:ring-offset-gray-900 transition-colors"
                aria-label="Visit my GitHub profile (opens in new tab)"
              >
                <GitHub class="w-4 h-4 text-gray-300" aria-hidden="true" />
              </a>
              <a
                href="https://linkedin.com/in/aycarl"
                target="_blank"
                rel="noopener noreferrer"
                class="p-2 rounded-lg bg-gray-800 hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-blue-400 focus:ring-offset-2 focus:ring-offset-gray-900 transition-colors"
                aria-label="Visit my LinkedIn profile (opens in new tab)"
              >
                <LinkedIn class="w-4 h-4 text-gray-300" aria-hidden="true" />
              </a>
              <a
                href="https://behance.net/aycarl"
                target="_blank"
                rel="noopener noreferrer"
                class="p-2 rounded-lg bg-gray-800 hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-blue-400 focus:ring-offset-2 focus:ring-offset-gray-900 transition-colors"
                aria-label="Visit my Behance portfolio (opens in new tab)"
              >
                <Behance class="w-4 h-4 text-gray-300" aria-hidden="true" />
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="pt-6 sm:pt-8 border-t border-gray-800 flex flex-col sm:flex-row justify-between items-center gap-3 sm:gap-4 text-center sm:text-left">
      <p class="text-xs sm:text-sm text-gray-400">
        © {new Date().getFullYear()} Carl Yao Agbenyega. All rights reserved.
      </p>
      <p class="text-xs sm:text-sm text-gray-400">
        Built with <span class="text-blue-400">Astro</span> & <span class="text-blue-400">TailwindCSS</span>
      </p>
    </div>
  </div>
</footer>
