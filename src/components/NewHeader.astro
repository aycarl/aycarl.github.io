---
import Email from './icons/Email.astro';
---

<header class="fixed top-0 left-0 right-0 z-50 bg-white/80 backdrop-blur-sm border-b border-gray-200" role="banner">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8" aria-label="Main navigation">
    <div class="flex items-center justify-between h-16">
      <!-- Logo/Name -->
      <a
        href="/"
        class="flex items-center space-x-2 group focus:outline-none focus:ring-2 focus:ring-blue-600 focus:ring-offset-2 rounded-lg"
        aria-label="Carl Agbenyega - Home"
      >
        <div class="w-10 h-10 rounded-full bg-gradient-to-br from-blue-500 to-purple-600 flex items-center justify-center text-white font-bold text-lg" aria-hidden="true">
          CA
        </div>
        <span class="font-bold text-xl hidden sm:block group-hover:text-blue-600 transition-colors">
          Carl Agbenyega
        </span>
      </a>

      <!-- Navigation & Actions -->
      <div class="flex items-center space-x-1 sm:space-x-2">
        <nav class="hidden md:flex items-center space-x-1" aria-label="Primary navigation">
          <a
            href="/#experience"
            class="px-3 py-2 text-sm font-medium text-gray-700 hover:text-blue-600 hover:bg-gray-100 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-600 transition-colors"
          >
            Experience
          </a>
          <a
            href="/#education"
            class="px-3 py-2 text-sm font-medium text-gray-700 hover:text-blue-600 hover:bg-gray-100 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-600 transition-colors"
          >
            Education
          </a>
          <a
            href="/#skills"
            class="px-3 py-2 text-sm font-medium text-gray-700 hover:text-blue-600 hover:bg-gray-100 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-600 transition-colors"
          >
            Skills
          </a>
          <a
            href="/blog"
            class="px-3 py-2 text-sm font-medium text-gray-700 hover:text-blue-600 hover:bg-gray-100 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-600 transition-colors"
          >
            Blog
          </a>
          <a
            href="/docs"
            class="px-3 py-2 text-sm font-medium text-gray-700 hover:text-blue-600 hover:bg-gray-100 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-600 transition-colors"
          >
            Docs
          </a>
        </nav>
        <div class="hidden md:block w-px h-6 bg-gray-300" aria-hidden="true"></div>
        <a
          href="mailto:aycarl@hotmail.com"
          class="p-2 rounded-lg hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-600 transition-colors"
          aria-label="Send me an email"
        >
          <Email class="w-5 h-5 text-gray-700" aria-hidden="true" />
        </a>
      </div>
    </div>
  </nav>
</header>
